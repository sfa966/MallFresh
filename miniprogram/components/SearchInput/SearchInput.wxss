.search_input{
  height: 100rpx;
  padding: 15rpx;
  background-color: var(--themeColor);
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 100;
}
.search_input navigator{
  height: 100%;
  border-radius: 15rpx;
  color: #666;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: white;
}